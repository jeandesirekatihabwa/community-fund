# Server Configuration
PORT=3001
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:5173

# Database (Production should use DATABASE_URL for Postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Stripe Keys (Found in Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# IMPORTANT: Mandatory for production to record successful payments
# Get this by running: stripe listen --forward-to localhost:3001/api/webhook
# Or from the Stripe Dashboard Webhook settings in production
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Auth (Found in Google Cloud Console)
GOOGLE_CLIENT_ID=...

# Redis (Mandatory if deploying multiple server instances/horizontal scaling)
# REDIS_URL=redis://localhost:6379
